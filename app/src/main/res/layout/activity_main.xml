<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A6ADC5">

    <!-- TOP HEADER / SEARCH CONTAINER -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:paddingLeft="20dp"
        android:paddingTop="25dp"
        android:paddingRight="20dp"
        android:paddingBottom="15dp">

        <!-- NORMAL HEADER CONTENT -->
        <RelativeLayout
            android:id="@+id/normalHeaderContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentLeft="true"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginLeft="15dp"
                android:layout_toRightOf="@id/imgMenu"
                android:text="Notes"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgSearchIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginRight="15dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:id="@+id/imgLogout"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </RelativeLayout>

        <!-- SEARCH BAR (HIDES/SHOWS IN PLACE OF HEADER) -->
        <LinearLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgCloseSearch"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginRight="12dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_fab_option"
                android:backgroundTint="#FFFFFF"
                android:hint="Search notes..."
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:textColor="#12121A"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />

        </LinearLayout>
    </RelativeLayout>

    <!-- RECYCLER VIEW - ALWAYS BELOW HEADER, NO OVERLAPPING -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNotes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBottomBar"
        android:layout_below="@id/layoutHeader"
        android:padding="10dp" />

    <!-- FLOATING ACTION BUTTON -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/layoutBottomBar"
        android:layout_alignParentRight="true"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="6dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#6542FF"
        app:fabCustomSize="56dp"
        app:maxImageSize="28dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
        app:tint="#FFFFFF" />

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="#A6ADC5"
        android:orientation="horizontal"
        android:weightSum="2" />

    <!-- OPTIONS (TEXT / VOICE) -->
    <LinearLayout
        android:id="@+id/btnlayout"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_above="@+id/fabAddNote"
        android:layout_alignParentRight="true"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/writetext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_fab_option"
            android:gravity="center"
            android:padding="12dp"
            android:text="Text"
            android:textColor="#12121A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/btnVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_fab_option"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#12121A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:text="Voice"
                android:textColor="#12121A"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>